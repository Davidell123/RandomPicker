<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alege Categoria:"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerCategory"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnPickRandom"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Alege Random"
        android:textSize="18sp"/>

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rezultatul va aparea aici"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="50dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ai o idee noua? Adaug-o mai jos:"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etNewIdea"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Ex: Sushi..."
        android:inputType="text"/>

    <Button
        android:id="@+id/btnAddIdea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Adauga Ideea"
        android:layout_marginTop="10dp"/>

</LinearLayout>